# Database — PostgreSQL (Neon recommended)
# 1. Create a free database at https://neon.tech
# 2. Copy the connection string from the Neon dashboard (use the "pooled" URL)
# 3. Paste it below, then copy this file to `.env`
DATABASE_URL="postgresql://user:password@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Public site URL (update to your Vercel deployment URL)
NEXT_PUBLIC_SITE_URL="https://your-project.vercel.app"

# Seed / demo
NEXT_PUBLIC_PAYMENT_PROVIDER=mock

# Paynow (production/sandbox)
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
PAYNOW_RESULT_URL=https://your-domain.com/api/paynow/result
PAYNOW_RETURN_URL=https://your-domain.com/checkout/confirmation

# Email notifications (optional - used by server actions)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_EMAIL=orders@synergydynamics.co.zw
